{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "color": {
      "type": "string",
      "enum": ["red", "green", "blue"],
      "description": "Select a primary color"
    },
    "size": {
      "type": "string",
      "enum": ["small", "medium", "large"],
      "description": "Select a size"
    }
  },
  "required": ["color"]
}
