{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "User's name"
    },
    "topic": {
      "type": "string",
      "description": "Topic to discuss"
    }
  },
  "required": ["name", "topic"]
}
