{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "original": {
      "type": "string",
      "description": "The original message"
    },
    "processed": {
      "type": "string",
      "description": "The processed message"
    },
    "length": {
      "type": "integer",
      "description": "The length of the message"
    }
  },
  "required": ["original", "processed", "length"]
}
