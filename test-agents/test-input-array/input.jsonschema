{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of strings"
    },
    "numbers": {
      "type": "array",
      "items": {
        "type": "integer"
      },
      "description": "Array of integers"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "integer" }
        }
      },
      "description": "Array of objects"
    }
  }
}
