{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ayo.dev/schemas/ayo.json",
  "title": "Ayo Config",
  "description": "Unified configuration for ayo agents and squads",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE support"
    },
    "version": {
      "type": "string",
      "description": "Configuration schema version",
      "enum": ["1"],
      "default": "1"
    },
    "agent": {
      "type": "object",
      "description": "Agent configuration (for agent ayo.json files)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Agent display name"
        },
        "handle": {
          "type": "string",
          "description": "Agent handle (e.g., @myagent)",
          "pattern": "^@?[a-z][a-z0-9-]*$"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the agent"
        },
        "model": {
          "type": "string",
          "description": "LLM model to use",
          "examples": ["gpt-4.1", "claude-sonnet-4-20250514", "gemini-2.5-pro"]
        },
        "provider": {
          "type": "string",
          "description": "LLM provider",
          "enum": ["openai", "anthropic", "google", "openrouter", "azure", "bedrock", "vertex", "groq", "mistral", "together", "fireworks", "deepseek", "xai"]
        },
        "tools": {
          "type": "array",
          "description": "List of tools available to this agent",
          "items": {
            "type": "string"
          },
          "examples": [["bash", "edit", "view", "grep", "glob"]]
        },
        "skills": {
          "type": "array",
          "description": "Skills to inject into the agent's context",
          "items": {
            "type": "string"
          }
        },
        "permissions": {
          "type": "object",
          "description": "Permission settings",
          "properties": {
            "auto_run": {
              "type": "boolean",
              "description": "Allow running commands without confirmation"
            },
            "file_edit": {
              "type": "boolean",
              "description": "Allow editing files"
            },
            "network": {
              "type": "boolean",
              "description": "Allow network access"
            }
          },
          "additionalProperties": false
        },
        "context": {
          "type": "object",
          "description": "Context configuration",
          "properties": {
            "max_tokens": {
              "type": "integer",
              "description": "Maximum context tokens"
            },
            "include_files": {
              "type": "array",
              "description": "Files to always include in context",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "delegates": {
          "type": "object",
          "description": "Map task types to other agents",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "squad": {
      "type": "object",
      "description": "Squad configuration (for squad ayo.json files)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Squad name"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the squad"
        },
        "lead": {
          "type": "string",
          "description": "Squad lead agent handle",
          "pattern": "^@?[a-z][a-z0-9-]*$",
          "default": "@ayo"
        },
        "agents": {
          "type": "array",
          "description": "List of agent handles in this squad",
          "items": {
            "type": "string",
            "pattern": "^@?[a-z][a-z0-9-]*$"
          }
        },
        "input_accepts": {
          "type": "string",
          "description": "Agent that receives direct input (defaults to lead)",
          "pattern": "^@?[a-z][a-z0-9-]*$"
        },
        "planners": {
          "type": "object",
          "description": "Planner configuration",
          "properties": {
            "near_term": {
              "type": "string",
              "description": "Near-term planner plugin",
              "default": "ayo-todos"
            },
            "long_term": {
              "type": "string",
              "description": "Long-term planner plugin",
              "default": "ayo-tickets"
            }
          },
          "additionalProperties": false
        },
        "io": {
          "type": "object",
          "description": "Input/output schema configuration",
          "properties": {
            "input_schema": {
              "type": "string",
              "description": "Path to input JSON schema"
            },
            "output_schema": {
              "type": "string",
              "description": "Path to output JSON schema"
            }
          },
          "additionalProperties": false
        },
        "coordination": {
          "type": "object",
          "description": "Coordination settings",
          "properties": {
            "ticket_workflow": {
              "type": "string",
              "description": "Ticket workflow type",
              "enum": ["kanban", "scrum", "simple"]
            },
            "auto_assign": {
              "type": "boolean",
              "description": "Automatically assign tickets to agents"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "oneOf": [
    {
      "required": ["agent"],
      "properties": {
        "squad": false
      }
    },
    {
      "required": ["squad"],
      "properties": {
        "agent": false
      }
    },
    {
      "properties": {
        "agent": false,
        "squad": false
      }
    }
  ]
}
